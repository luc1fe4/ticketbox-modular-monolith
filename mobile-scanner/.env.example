# Use localhost for Expo Web, 10.0.2.2 for the Android emulator, or the
# development computer's LAN IP for a physical device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Maximum number of pending offline check-ins uploaded in one sync request.
EXPO_PUBLIC_MAX_SYNC_BATCH_SIZE=500

# Ignore the same camera QR code for this many milliseconds after a scan.
EXPO_PUBLIC_SCAN_DUPLICATE_WINDOW_MS=3000
