{
	"info": {
		"name": "TicketBox - Ticket Type API",
		"description": "Endpoints for managing and checking ticket types/zones.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "concertId",
			"value": "11111111-1111-1111-1111-111111111111",
			"type": "string"
		},
		{
			"key": "ticketTypeId",
			"value": "00000000-0000-0000-0000-000000000000",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. GET Public Ticket Types",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/concerts/{{concertId}}/ticket-types",
					"host": ["{{baseUrl}}"],
					"path": ["api", "concerts", "{{concertId}}", "ticket-types"]
				},
				"description": "Retrieve active ticket types for a concert."
			}
		},
		{
			"name": "2. GET Public Availability",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/concerts/{{concertId}}/availability",
					"host": ["{{baseUrl}}"],
					"path": ["api", "concerts", "{{concertId}}", "availability"]
				},
				"description": "Retrieve real-time available quantities by zone."
			}
		},
		{
			"name": "3. GET Admin Ticket Types",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/admin/concerts/{{concertId}}/ticket-types",
					"host": ["{{baseUrl}}"],
					"path": ["api", "admin", "concerts", "{{concertId}}", "ticket-types"]
				},
				"description": "Organizer view of all ticket types (active and inactive)."
			}
		},
		{
			"name": "4. POST Admin Create Ticket Type",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"SVIP\",\n  \"price\": 3500000,\n  \"totalQuantity\": 200,\n  \"maxPerAccount\": 2,\n  \"saleStartAt\": \"2026-07-01T12:00:00+07:00\",\n  \"saleEndAt\": \"2026-08-01T16:59:59+07:00\",\n  \"zoneColor\": \"#E11D48\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/admin/concerts/{{concertId}}/ticket-types",
					"host": ["{{baseUrl}}"],
					"path": ["api", "admin", "concerts", "{{concertId}}", "ticket-types"]
				},
				"description": "Create a new ticket zone."
			}
		},
		{
			"name": "5. PUT Admin Update Ticket Type",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"SVIP (Updated)\",\n  \"price\": 3800000,\n  \"totalQuantity\": 250,\n  \"maxPerAccount\": 2,\n  \"saleStartAt\": \"2026-07-01T12:00:00+07:00\",\n  \"saleEndAt\": \"2026-08-01T16:59:59+07:00\",\n  \"zoneColor\": \"#E11D48\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/admin/ticket-types/{{ticketTypeId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "admin", "ticket-types", "{{ticketTypeId}}"]
				},
				"description": "Update metadata of a ticket type."
			}
		},
		{
			"name": "6. PATCH Admin Change Status",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"isActive\": false\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/admin/ticket-types/{{ticketTypeId}}/status",
					"host": ["{{baseUrl}}"],
					"path": ["api", "admin", "ticket-types", "{{ticketTypeId}}", "status"]
				},
				"description": "Deactivate or activate a ticket zone."
			}
		},
		{
			"name": "7. DELETE Admin Delete Ticket Type",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/admin/ticket-types/{{ticketTypeId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "admin", "ticket-types", "{{ticketTypeId}}"]
				},
				"description": "Delete a ticket zone."
			}
		}
	]
}
