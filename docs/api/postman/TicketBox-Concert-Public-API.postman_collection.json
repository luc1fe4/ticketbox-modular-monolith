{
	"info": {
		"name": "TicketBox - Concert Public API",
		"description": "Public API endpoints for browsing concerts.\n\nTask 1: Concert list/detail with artist_bio.\n\nNo authentication required.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. List Concerts (default)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/concerts",
					"host": ["{{baseUrl}}"],
					"path": ["api", "concerts"]
				},
				"description": "Get the first page of public concerts (ON_SALE or SOLD_OUT).\n\nDefault: page=0, size=10, sorted by eventDate ascending."
			}
		},
		{
			"name": "2. List Concerts (with pagination)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/concerts?page=0&size=5",
					"host": ["{{baseUrl}}"],
					"path": ["api", "concerts"],
					"query": [
						{
							"key": "page",
							"value": "0",
							"description": "Page number (0-based)"
						},
						{
							"key": "size",
							"value": "5",
							"description": "Number of concerts per page"
						}
					]
				},
				"description": "Get concerts with custom pagination.\n\nTry changing page=1 to see the next page."
			}
		},
		{
			"name": "3. Get Concert Detail",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/concerts/11111111-1111-1111-1111-111111111111",
					"host": ["{{baseUrl}}"],
					"path": ["api", "concerts", "11111111-1111-1111-1111-111111111111"]
				},
				"description": "Get full concert detail including artist_bio.\n\nUsing the 'Anh Trai Say Hi' concert from test data."
			}
		},
		{
			"name": "4. Get Concert Detail (404 - Not Found)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/concerts/00000000-0000-0000-0000-000000000000",
					"host": ["{{baseUrl}}"],
					"path": ["api", "concerts", "00000000-0000-0000-0000-000000000000"]
				},
				"description": "Test the 404 error case.\n\nThis UUID doesn't exist, so the API should return a 404 error response."
			}
		}
	]
}
