{
  "info": {
    "_postman_id": "d8b7d6f4-19e1-4f29-88f5-6f9cc56a8f10",
    "name": "TicketBox - Order Payment Flow",
    "description": "Focused Postman collection for testing seeded concert purchase, order creation, mock payment success, and ticket issuance.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login Seeded Audience",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json.data && json.data.accessToken) {",
              "  pm.collectionVariables.set('token', json.data.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"audience@ticketbox.com\",\n  \"password\": \"password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Check Seeded Concert Detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/concerts/{{concertId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "concerts",
            "{{concertId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Check Seeded Seat Map",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/concerts/{{concertId}}/seat-map",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "concerts",
            "{{concertId}}",
            "seat-map"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Check Seeded Ticket Types",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/concerts/{{concertId}}/ticket-types",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "concerts",
            "{{concertId}}",
            "ticket-types"
          ]
        }
      },
      "response": []
    },
    {
      "name": "5. Create Order - SVIP x1 + VIP x2",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('idempotencyKey', 'postman-order-' + pm.variables.replaceIn('{{$guid}}'));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Order created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json.data && json.data.id) {",
              "  pm.collectionVariables.set('orderId', json.data.id);",
              "}",
              "",
              "pm.test('Order awaits payment', function () {",
              "  pm.expect(json.data.status).to.eql('AWAITING_PAYMENT');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Idempotency-Key",
            "value": "{{idempotencyKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"concertId\": \"{{concertId}}\",\n  \"items\": [\n    {\n      \"ticketTypeId\": \"{{svipTicketTypeId}}\",\n      \"quantity\": 1\n    },\n    {\n      \"ticketTypeId\": \"{{vipTicketTypeId}}\",\n      \"quantity\": 2\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
      },
      "response": []
    },
    {
      "name": "6. Get Order Before Payment",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "7. Initiate VNPAY Payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Payment initiated', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json.data && json.data.paymentUrl) {",
              "  pm.collectionVariables.set('paymentUrl', json.data.paymentUrl);",
              "  console.log('Open this VNPAY URL:', json.data.paymentUrl);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"provider\": \"VNPAY\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/payments/{{orderId}}/initiate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payments",
            "{{orderId}}",
            "initiate"
          ]
        }
      },
      "response": []
    },
    {
      "name": "8. Mock Payment Success Fallback",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/mock-payments/{{orderId}}/success",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "mock-payments",
            "{{orderId}}",
            "success"
          ]
        }
      },
      "response": []
    },
    {
      "name": "9. Get Order After Payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Order is paid', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.status).to.eql('PAID');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "{{orderId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "10. List My Tickets",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets"
          ]
        }
      },
      "response": []
    },
    {
      "name": "11. List My Notifications",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notifications"
          ]
        }
      },
      "response": []
    }
  ],
