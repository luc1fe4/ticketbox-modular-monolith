								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Idempotency-Key",
								"value": "unique-idempotency-key-string-123456",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"concertId\": \"{{concertId}}\",\n    \"items\": [\n        {\n            \"ticketTypeId\": \"{{ticketTypeId}}\",\n            \"quantity\": 2\n        }\n    ]\n}",
