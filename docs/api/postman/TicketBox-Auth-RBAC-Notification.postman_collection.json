								"exec": [
									"var jsonData = pm.response.json();",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"if (jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set(\"audience_token\", jsonData.data.accessToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"audience@ticketbox.vn\",\n    \"password\": \"password123\"\n}",
